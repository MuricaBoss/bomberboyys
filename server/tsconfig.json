{
  "compilerOptions": {
    "target": "ES2019",
    "module": "node16",
    "moduleResolution": "node16",
    "useDefineForClassFields": false,
    "rootDir": "./src",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "src"
  ]
}
